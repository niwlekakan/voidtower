# Copy this to .env and fill in your values before running docker compose.

# ── VoidTower image ────────────────────────────────────────────────────────────
# Pin to a specific release tag to control when you update, e.g.:
#   VOIDTOWER_IMAGE=ghcr.io/niwlekakan/voidtower:aio-v1.2.3
# Leave unset to always use the latest build from the main branch.
# VOIDTOWER_IMAGE=ghcr.io/niwlekakan/voidtower:aio-latest

# ── Odysseus ──────────────────────────────────────────────────────────────────
# Admin credentials for the Odysseus web UI (set before first start)
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=changeme

# Port Odysseus is reachable on from the host (default: localhost only)
ODYSSEUS_PORT=7000
ODYSSEUS_BIND=127.0.0.1

# ── Voidwatch ─────────────────────────────────────────────────────────────────
# After completing VoidTower bootstrap:
#   1. Go to Settings → Integrations → API Tokens → New Token
#   2. Paste the token here and restart: docker compose restart odysseus
VOIDWATCH_TOKEN=

# Generate with: openssl rand -hex 32
VOIDWATCH_WEBHOOK_SECRET=

# ── AI provider ───────────────────────────────────────────────────────────────
# If using --profile ai (Ollama container), leave this as-is.
# To use a remote or host Ollama instance instead, set the URL here:
# OLLAMA_BASE_URL=http://192.168.1.5:11434

# To use an external OpenAI-compatible endpoint instead of Ollama:
# OLLAMA_BASE_URL=http://192.168.1.5:8080/v1
# OPENAI_API_KEY=sk-...

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Auto-generated on first run if left blank
SEARXNG_SECRET=

# ── File ownership (match your host user) ─────────────────────────────────────
# Find with: id -u && id -g
PUID=1000
PGID=1000
