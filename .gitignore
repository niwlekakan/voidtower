# Rust
/backend/target/
**/*.rs.bk

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Dev data (local state, not for VCS)
backend/dev-data/
# App catalog is product content — track it
!backend/dev-data/apps/

# Dev config (local secrets/tokens, never commit)
backend/dev-config/

# Claude Code working files (agent worktrees, memory, session state)
.claude/
CLAUDE.md

# Editor metadata
.obsidian/
.directory
.vscode/
*.code-workspace

# Local planning / scratch docs
plan.md
future_plan.md
UI_plan.md
*_plan.md

# Root-level dev database (backend/dev-data/ is already ignored above)
dev-data/*.db
dev-data/*.db-shm
dev-data/*.db-wal
dev-data/apps/

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
*.key
bootstrap-token

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor
.vscode/settings.json
.idea/
*.suo
*.user

# Build artifacts
dist/
build/
release/
*.deb
*.rpm
*.tar.gz
*.tar.xz

# design-sync — staged scripts, build output, and machine-local state (not for VCS)
# (/* not a trailing-/ dir-ignore: a dir-ignore blocks git from ever looking
# inside it, so the entry.ts negation below wouldn't take effect)
frontend/.ds-sync/*
# ...except entry.ts: the hand-authored synthetic barrel (which components are
# exported to the converter), not a disposable staged script — would be
# silently lost on a fresh clone otherwise.
!frontend/.ds-sync/entry.ts
frontend/ds-bundle/
frontend/.design-sync/.cache/
frontend/.design-sync/learnings/
frontend/.design-sync/node_modules
