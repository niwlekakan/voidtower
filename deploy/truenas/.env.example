# TrueNAS deployment environment variables
# Set these in Apps → Custom App → Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────
ODYSSEUS_ADMIN_PASSWORD=changeme

# ── Your TrueNAS pool name (default: tank) ────────────────────────────────────
# Data will be stored at /mnt/<TRUENAS_POOL>/voidtower/
TRUENAS_POOL=tank

# ── Voidwatch (fill in after VoidTower bootstrap) ─────────────────────────────
VOIDWATCH_TOKEN=
VOIDWATCH_WEBHOOK_SECRET=

# ── AI provider ───────────────────────────────────────────────────────────────
# Leave blank to use the bundled Ollama container (if uncommented in the YAML).
# Or point at an existing Ollama instance on your LAN:
# OLLAMA_BASE_URL=http://192.168.1.5:11434

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Auto-generated on first run if left blank
SEARXNG_SECRET=
