    "ConfirmDialog": "../src/components/ui/ConfirmDialog.tsx",
    "LogViewer": "../src/components/ui/LogViewer.tsx",
    "AnimatedBackground": "../src/components/ui/AnimatedBackground.tsx",
    "AppEmbedOverlay": "../src/components/ui/AppEmbedOverlay.tsx",
    "CommandPalette": "../src/components/ui/CommandPalette.tsx",
    "ForcePasswordChange": "../src/components/ui/ForcePasswordChange.tsx",
    "MiniTerminal": "../src/components/ui/MiniTerminal.tsx",
    "NotificationToasts": "../src/components/ui/NotificationToasts.tsx",
    "SendToOdysseus": "../src/components/ui/SendToOdysseus.tsx",
    "ThemeEditor": "../src/components/ui/ThemeEditor.tsx"
